# =============================================================================
# Beaver Agent — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# The .gitignore already excludes it, but double-check before pushing.
# =============================================================================


# --- LLM API Keys (at least one LLM key is required) ---
GOOGLE_API_KEY=your_google_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here          # Optional: fallback LLM provider

# --- Search / Research ---
TAVILY_API_KEY=your_tavily_api_key_here       # Optional: enables company research

# --- Security ---
# API_KEY: If set, all /process and /history calls must include header:
#   X-API-Key: <value>
# Leave empty to disable authentication (development only).
API_KEY=

# ALLOWED_ORIGINS: Comma-separated list of allowed frontend origins.
# In production, set to your actual frontend domain, e.g.:
#   ALLOWED_ORIGINS=https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MAX_EMAIL_LENGTH: Maximum characters accepted in email_text field.
MAX_EMAIL_LENGTH=10000

# --- App ---
DEBUG=False
LOG_LEVEL=INFO

# --- Google OAuth (Gmail integration — optional) ---
# Only needed if you want the email poller to read from Gmail.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/callback
GOOGLE_TOKEN_FILE=token.json

# --- Email Poller ---
POLL_INTERVAL=60    # Seconds between Gmail inbox polls

# --- Model Configuration (optional overrides) ---
# ROUTER_MODEL=gemini-2.5-flash
# WRITER_MODEL=gemini-2.5-flash
# VERIFIER_MODEL=gemini-2.5-flash
# RESEARCHER_MODEL=gemini-2.5-flash
# MAX_REVISIONS=3
# RECURSION_LIMIT=15

# --- Database ---
DB_NAME=beaver.db

# =============================================================================
# SaaS Configuration (for full product deployment)
# =============================================================================

# --- Supabase (Auth + Database) ---
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret   # Settings > API > JWT Secret

# --- Stripe (Billing) ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id

